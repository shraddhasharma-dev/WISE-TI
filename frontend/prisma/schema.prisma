generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Participant {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  college    String
  skill      String
  createdAt  DateTime @default(now())

  teamId     Int?
  team       Team?    @relation(fields: [teamId], references: [id])
}

model Team {
  id            Int            @id @default(autoincrement())
  name          String
  status        String         @default("DRAFT")
  rationale     String?

  participants  Participant[]
  evaluations   Evaluation[]
}

model Judge {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique

  evaluations   Evaluation[]
}

model Evaluation {
  id          Int      @id @default(autoincrement())
  score       Float
  comments    String?

  judgeId     Int
  teamId      Int

  judge       Judge    @relation(fields: [judgeId], references: [id])
  team        Team     @relation(fields: [teamId], references: [id])
}

model Event {
  id            Int      @id @default(autoincrement())
  name          String
  currentStage  String
}